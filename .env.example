# ==============================================================
# AI Lab Assistant - Environment Configuration
# Copy this file to .env and adjust values for your environment
# ==============================================================

# --- General ---
APP_ENV=development
LOG_LEVEL=INFO

# --- API Gateway ---
API_HOST=0.0.0.0
API_PORT=8000

# --- ASR Service ---
ASR_HOST=asr-service
ASR_PORT=8001
ASR_MODEL_SIZE=base
# Options: tiny, base, small, medium, large
# For PhoWhisper: vinai/PhoWhisper-base, vinai/PhoWhisper-small, etc.
ASR_LANGUAGE=vi
ASR_DEVICE=cpu
# Options: cpu, cuda

# --- LLM Service (Ollama) ---
# If Ollama is installed on host, use host.docker.internal (Docker)
# or localhost (local development)
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_MODEL=qwen3:8b
# Fallback for weaker machines: qwen3:4b

# --- LLM Service Wrapper ---
LLM_HOST=llm-service
LLM_PORT=8003

# --- TTS Service ---
TTS_HOST=tts-service
TTS_PORT=8002
TTS_ENGINE=edge-tts
# Options: edge-tts, piper, vixtts
TTS_VOICE=vi-VN-HoaiMyNeural
# Edge TTS Vietnamese voices:
#   vi-VN-HoaiMyNeural (female)
#   vi-VN-NamMinhNeural (male)

# --- Database (Phase 2+) ---
POSTGRES_DB=ai_lab
POSTGRES_USER=ai_lab
POSTGRES_PASSWORD=ai_lab_password_change_me
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Redis (Phase 2+) ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- Qdrant (Phase 2 - RAG) ---
QDRANT_HOST=qdrant
QDRANT_PORT=6333
